<style>
body { font-family: Arial, sans-serif; margin: 0; padding: 0; color: #333; scroll-behavior: smooth; }
body.dark-mode { background-color: #1a1a1a; color: #f5f5f5; }
header { background-color: #2a2a2a; color:blue; padding: 40px 20px; text-align: center; position: relative; }
header h1 { font-size: 2.5em; margin-bottom: 10px; }
header p { font-size: 1.2em; margin-bottom: 20px; }
header .cta { background-color: #6a0dad; color:blue; padding: 10px 20px; text-decoration: none; border-radius: 5px; }
header .cta:hover { background-color: #8b2dd8; }
section { padding: 60px 20px; max-width: 1200px; margin: 0 auto; }
h2 { font-size: 2em; margin-bottom: 20px; color: #2a2a2a; text-align: center; }
body.dark-mode h2 { color: #e0c0ff; }
/* SERVICE STYLES */
.services { display: flex; flex-wrap: wrap; gap: 20px; justify-content: center; }
.service { flex: 1 1 calc(33% - 20px); background-color: #f5f5f5; padding: 20px; border-radius: 10px; box-shadow: 0 4px 10px rgba(0,0,0,0.1); text-align: center; transition: transform 0.3s, box-shadow 0.3s; cursor: pointer; }
.service:focus, .service:hover { outline: 3px solid #6a0dad; transform: scale(1.03); }
body.dark-mode .service { background-color: #2a2a2a; color: #f5f5f5; }
.service-icon { width: 60px; height: 60px; margin: 0 auto 10px; transform: scale(0); transition: transform 0.6s ease-out; }
.service:hover .service-icon, .service:focus .service-icon { transform: scale(1.1); }
/* ACCESSIBLE FOCUS STYLES */
:focus { outline: 3px solid #6a0dad; outline-offset: 4px; }
/* STATS */
.stats { display: flex; justify-content: space-around; margin-top: 40px; }
.stat { text-align: center; position: relative; }
.stat-number { font-size: 2em; color: #6a0dad; margin-bottom: 10px; }
.stat-svg { width: 80px; height: 80px; transform: rotate(-90deg); margin: 0 auto 10px; }
.circle-bg { fill: none; stroke: #ddd; stroke-width: 8; }
.circle-progress { fill: none; stroke: #6a0dad; strmuoke-width: 8; stroke-linecap: round; stroke-dasharray: 251.2; stroke-dashoffset: 251.2; transition: stroke-dashoffset 1s ease-in-out; }
</style>
  <style>
    /* Theme transition animation */
    :root {
      --transition-speed: 0.4s;
    }
    html {
      transition: background-color var(--transition-speed) ease, color var(--transition-speed) ease;
    }

    /* Theme variables */
    :root[data-theme='light'] {
      --bg: #ffffff;
      --text: #000000;
    }
    :root[data-theme='dark'] {
      --bg: #0f0f0f;
      --text: #f5f5f5;
    }

    /* Apply colors */
    body {
      background-color: var(--bg);
      color: var(--text);
    }

    /* Toggle button */
    #theme-toggle {
      position: fixed;
      top: 20px;
      right: 20px;
      padding: 10px 14px;
      background: var(--text);
      color: var(--bg);
      border-radius: 8px;
      cursor: pointer;
      z-index: 999;
    }

    /* Color palette */
    #palette {
      position: fixed;
      bottom: 20px;
      right: 20px;
      background: rgba(0,0,0,0.6);
      padding: 10px;
      border-radius: 8px;
      display: flex;
      gap: 10px;
      z-index: 999;
    }

    .color-swatch {
      width: 25px;
      height: 25px;
      border-radius: 4px;
      cursor: pointer;
      border: 2px solid white;
    }.metacard-section {
  padding: 3rem 1.5rem;
  border-top: 1px solid #ddd;
}

.metacard-subtitle {
  color: #555;
  max-width: 600px;
}

.metacard-content {
  display: flex;
  flex-wrap: wrap;
  gap: 2rem;
  margin-top: 1.5rem;
}

.metacard-details {
  list-style: none;
  padding: 0;
  margin: 0;
}

.metacard-details li {
  margin-bottom: 0.5rem;
}

.metacard-qr-placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  min-width: 180px;
  min-height: 180px;
  border: 2px dashed #999;
  color: #666;
  font-size: 0.9rem;
}
